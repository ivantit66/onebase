# Golden-фикстуры для onec_forms — хранятся в LF, бинарное сравнение в
# тестах. Без -text Windows autocrlf конвертирует в CRLF при checkout и
# roundtrip-тесты падают на «expected LF, got CRLF».
internal/onec_forms/fixtures/* -text

# Вендоренный Monaco — минифицированные ассеты, храним байт-в-байт без
# нормализации EOL, чтобы апгрейд версии давал чистый предсказуемый diff.
internal/webassets/monaco/** -text

# Встроенные TTF-шрифты для PDF (PT Serif/PT Sans, OFL) — бинарные, без
# нормализации EOL.
internal/sheet/fonts/*.ttf binary

# Golden-фикстуры HTML табличного документа — хранятся и сверяются в LF
# (рендер sheet.HTML даёт \n). Без -text Windows autocrlf конвертирует в CRLF
# при checkout и бит-в-бит сравнение в тестах падает.
internal/dsl/interpreter/testdata/golden/*.html -text
