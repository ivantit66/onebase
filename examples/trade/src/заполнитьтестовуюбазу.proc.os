    // ---- ЗАКАЗЫ ПОКУПАТЕЛЕЙ (3 шт.) ----

    ЗакПок1 = Документы.ЗаказПокупателя.Создать();
    ЗакПок1.Номер = "ЗП-00001";
    ЗакПок1.Дата = ДатаМес1; ЗакПок1.Организация = НашаОрг; ЗакПок1.Покупатель = ПокупательРемонт;
    ЗакПок1.Склад = СкладГлавный;
    ЗакПок1.Комментарий = "Срочный заказ — клиент строит дачу (третий год)";
    Стр = ЗакПок1.Товары.Добавить(); Стр.Номенклатура = НомДоска;   Стр.Количество = 50;  Стр.Цена = 480; Стр.Резерв = 50;
    Стр = ЗакПок1.Товары.Добавить(); Стр.Номенклатура = НомБрус;    Стр.Количество = 20;  Стр.Цена = 710; Стр.Резерв = 20;
    Стр = ЗакПок1.Товары.Добавить(); Стр.Номенклатура = НомЦемент;  Стр.Количество = 30;  Стр.Цена = 750; Стр.Резерв = 30;
    ЗакПок1.Записать(); ЗакПок1.Провести();

    ЗакПок2 = Документы.ЗаказПокупателя.Создать();
    ЗакПок2.Номер = "ЗП-00002";
    ЗакПок2.Дата = ДеньМ10; ЗакПок2.Организация = НашаОрг; ЗакПок2.Покупатель = ПокупательМагазин;
    ЗакПок2.Склад = СкладГлавный;
    ЗакПок2.Комментарий = "Магазин заказал замки — видимо, хотят закрыться от мира";
