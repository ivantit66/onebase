  // Сезонные позиции для демонстрации механизма «Активные / Скрытые / Все».
  // Они остаются в справочнике и отчётах, но не попадают в рабочий выбор товара.
  Если ЗначениеЗаполнено(Справочники.Номенклатура.НайтиПоНаименованию("Лопата снеговая «До весны»")) = Ложь Тогда
    Зап = Справочники.Номенклатура.Создать();
    Зап.Наименование     = "Лопата снеговая «До весны»";
    Зап.Артикул          = "SEZ-SNO-001";
    Зап.ЕдиницаИзмерения = ЕдШт;
    Зап.СтавкаНДС        = Ставка20;
    Зап.Группа           = "Сезонные товары";
    Зап.МинимальныйОстаток = 5;
    Зап.Активный         = Ложь;
    Зап.Записать();
  КонецЕсли;

  Если ЗначениеЗаполнено(Справочники.Номенклатура.НайтиПоНаименованию("Соль противогололёдная «Хрустит и тает» 25кг")) = Ложь Тогда
    Зап = Справочники.Номенклатура.Создать();
    Зап.Наименование     = "Соль противогололёдная «Хрустит и тает» 25кг";
    Зап.Артикул          = "SEZ-ICE-025";
    Зап.ЕдиницаИзмерения = ЕдШт;
    Зап.СтавкаНДС        = Ставка20;
    Зап.Группа           = "Сезонные товары";
    Зап.МинимальныйОстаток = 10;
    Зап.Активный         = Ложь;
    Зап.Записать();
  КонецЕсли;

  Сообщить("Справочники готовы.");

  // ============ ОЧИСТКА ДОКУМЕНТОВ ============

  Очищаем = (Параметры.Очистить <> Ложь);
  Если Очищаем Тогда
    Удал = 0;
    Попытка
      // Порядок удаления: сначала зависимые (потребители), потом источники
      ЗД = Новый Запрос; ЗД.Текст = "ВЫБРАТЬ Номер ИЗ Документ.СписаниеТоваров";
      Для Каждого Стр Из ЗД.Выполнить() Цикл
        Об = Документы.СписаниеТоваров.НайтиПоНомеру(Стр.Номер);
        Если ЗначениеЗаполнено(Об) Тогда Документы.СписаниеТоваров.Удалить(Об); Удал = Удал + 1; КонецЕсли;
      КонецЦикла;
      ЗД = Новый Запрос; ЗД.Текст = "ВЫБРАТЬ Номер ИЗ Документ.РеализацияТоваров";
      Для Каждого Стр Из ЗД.Выполнить() Цикл
        Об = Документы.РеализацияТоваров.НайтиПоНомеру(Стр.Номер);
        Если ЗначениеЗаполнено(Об) Тогда Документы.РеализацияТоваров.Удалить(Об); Удал = Удал + 1; КонецЕсли;
      КонецЦикла;
      ЗД = Новый Запрос; ЗД.Текст = "ВЫБРАТЬ Номер ИЗ Документ.ПеремещениеТоваров";
      Для Каждого Стр Из ЗД.Выполнить() Цикл
        Об = Документы.ПеремещениеТоваров.НайтиПоНомеру(Стр.Номер);
        Если ЗначениеЗаполнено(Об) Тогда Документы.ПеремещениеТоваров.Удалить(Об); Удал = Удал + 1; КонецЕсли;
      КонецЦикла;
      ЗД = Новый Запрос; ЗД.Текст = "ВЫБРАТЬ Номер ИЗ Документ.Инвентаризация";
      Для Каждого Стр Из ЗД.Выполнить() Цикл
        Об = Документы.Инвентаризация.НайтиПоНомеру(Стр.Номер);
        Если ЗначениеЗаполнено(Об) Тогда Документы.Инвентаризация.Удалить(Об); Удал = Удал + 1; КонецЕсли;
      КонецЦикла;
      ЗД = Новый Запрос; ЗД.Текст = "ВЫБРАТЬ Номер ИЗ Документ.ЗаказПокупателя";
      Для Каждого Стр Из ЗД.Выполнить() Цикл
        Об = Документы.ЗаказПокупателя.НайтиПоНомеру(Стр.Номер);
        Если ЗначениеЗаполнено(Об) Тогда Документы.ЗаказПокупателя.Удалить(Об); Удал = Удал + 1; КонецЕсли;
      КонецЦикла;
      ЗД = Новый Запрос; ЗД.Текст = "ВЫБРАТЬ Номер ИЗ Документ.ЗаказПоставщику";
      Для Каждого Стр Из ЗД.Выполнить() Цикл
        Об = Документы.ЗаказПоставщику.НайтиПоНомеру(Стр.Номер);
        Если ЗначениеЗаполнено(Об) Тогда Документы.ЗаказПоставщику.Удалить(Об); Удал = Удал + 1; КонецЕсли;
      КонецЦикла;
      ЗД = Новый Запрос; ЗД.Текст = "ВЫБРАТЬ Номер ИЗ Документ.ОприходованиеТоваров";
      Для Каждого Стр Из ЗД.Выполнить() Цикл
        Об = Документы.ОприходованиеТоваров.НайтиПоНомеру(Стр.Номер);
        Если ЗначениеЗаполнено(Об) Тогда Документы.ОприходованиеТоваров.Удалить(Об); Удал = Удал + 1; КонецЕсли;
      КонецЦикла;
      ЗД = Новый Запрос; ЗД.Текст = "ВЫБРАТЬ Номер ИЗ Документ.ПоступлениеТоваров";
      Для Каждого Стр Из ЗД.Выполнить() Цикл
        Об = Документы.ПоступлениеТоваров.НайтиПоНомеру(Стр.Номер);
        Если ЗначениеЗаполнено(Об) Тогда Документы.ПоступлениеТоваров.Удалить(Об); Удал = Удал + 1; КонецЕсли;
      КонецЦикла;
      Сообщить("Очищено документов: " + Строка(Удал));
    Исключение
      Сообщить("Очистка не выполнена: " + ОписаниеОшибки());
    КонецПопытки;
  КонецЕсли;

  ЗПест = Новый Запрос; ЗПест.Текст = "ВЫБРАТЬ Номер ИЗ Документ.ПоступлениеТоваров";
  ЕстьПост = Ложь;
  Для Каждого Д Из ЗПест.Выполнить() Цикл ЕстьПост = Истина; Прервать; КонецЦикла;
  Создавать = (ЕстьПост = Ложь);

  // ============ СОЗДАНИЕ И ПРОВЕДЕНИЕ ============
  // Все даты — свежие, в последние 14 дней, чтобы виджеты (30-дневные)
  // показывали данные.

  Если Создавать Тогда
    Сегодня = ТекущаяДата();
    ДатаМес5 = ДобавитьМесяц(Сегодня, -5);
    ДатаМес4 = ДобавитьМесяц(Сегодня, -4);
    ДатаМес3 = ДобавитьМесяц(Сегодня, -3);
    ДатаМес2 = ДобавитьМесяц(Сегодня, -2);
    ДатаМес1 = ДобавитьМесяц(Сегодня, -1);
    ДеньМ28 = Сегодня - 28*86400;
    ДеньМ25 = Сегодня - 25*86400;
    ДеньМ22 = Сегодня - 22*86400;
    ДеньМ19 = Сегодня - 19*86400;
    ДеньМ16 = Сегодня - 16*86400;
    ДеньМ14 = Сегодня - 14*86400;
    ДеньМ12 = Сегодня - 12*86400;
    ДеньМ10 = Сегодня - 10*86400;
    ДеньМ8  = Сегодня - 8*86400;
    ДеньМ6  = Сегодня - 6*86400;
    ДеньМ4  = Сегодня - 4*86400;
    ДеньМ2  = Сегодня - 2*86400;
    ДеньМ1  = Сегодня - 1*86400;

    // ---- ЗАКАЗЫ ПОСТАВЩИКАМ (-5...-4 мес) ----

    ЗакПост1 = Документы.ЗаказПоставщику.Создать();
    ЗакПост1.Номер = "ЗПС-00001";
    ЗакПост1.Дата = ДатаМес5; ЗакПост1.Организация = НашаОрг; ЗакПост1.Поставщик = ПоставщикДоски;
    ЗакПост1.СкладНазначения = СкладГлавный;
    ЗакПост1.ОжидаемаяДата = ДатаМес5;
    ЗакПост1.Комментарий = "Доски и брус — основа основ, как говорил дед";
    Стр = ЗакПост1.Товары.Добавить(); Стр.Номенклатура = НомДоска;  Стр.Количество = 200; Стр.Цена = 350;
    Стр = ЗакПост1.Товары.Добавить(); Стр.Номенклатура = НомБрус;   Стр.Количество = 80;  Стр.Цена = 520;
    ЗакПост1.Записать(); ЗакПост1.Провести();

    ЗакПост2 = Документы.ЗаказПоставщику.Создать();
    ЗакПост2.Номер = "ЗПС-00002";
    ЗакПост2.Дата = ДатаМес5; ЗакПост2.Организация = НашаОрг; ЗакПост2.Поставщик = ПоставщикГвоздь;
    ЗакПост2.СкладНазначения = СкладГлавный;
    ЗакПост2.ОжидаемаяДата = ДатаМес5;
    ЗакПост2.Комментарий = "Гвозди, саморезы — без них ничего не держится";
    Стр = ЗакПост2.Товары.Добавить(); Стр.Номенклатура = НомГвоздь;   Стр.Количество = 300; Стр.Цена = 85;
    Стр = ЗакПост2.Товары.Добавить(); Стр.Номенклатура = НомСаморез;  Стр.Количество = 500; Стр.Цена = 3;
    ЗакПост2.Записать(); ЗакПост2.Провести();

    ЗакПост3 = Документы.ЗаказПоставщику.Создать();
    ЗакПост3.Номер = "ЗПС-00003";
    ЗакПост3.Дата = ДатаМес4; ЗакПост3.Организация = НашаОрг; ЗакПост3.Поставщик = ПоставщикФурнитура;
    ЗакПост3.СкладНазначения = СкладГлавный;
    ЗакПост3.ОжидаемаяДата = ДатаМес4;
    Стр = ЗакПост3.Товары.Добавить(); Стр.Номенклатура = НомПетля;  Стр.Количество = 100; Стр.Цена = 180;
    Стр = ЗакПост3.Товары.Добавить(); Стр.Номенклатура = НомЗамок;  Стр.Количество = 50;  Стр.Цена = 450;
    ЗакПост3.Записать(); ЗакПост3.Провести();

    Сообщить("Заказы поставщикам (3 шт.) проведены.");

    // ---- ПОСТУПЛЕНИЯ ТОВАРОВ (8 шт., размазаны по месяцам) ----

    Пост1 = Документы.ПоступлениеТоваров.Создать();
    Пост1.Номер = "ПТ-00001";
    Пост1.Дата = ДатаМес5; Пост1.Организация = НашаОрг; Пост1.Поставщик = ПоставщикДоски;
    Пост1.Склад = СкладГлавный;
    Стр = Пост1.Товары.Добавить(); Стр.Номенклатура = НомДоска; Стр.Количество = 200; Стр.Цена = 350; Стр.МестоХранения = МестоСтеллаж1;
    Стр = Пост1.Товары.Добавить(); Стр.Номенклатура = НомБрус;  Стр.Количество = 80;  Стр.Цена = 520; Стр.МестоХранения = МестоСтеллаж2;
    Пост1.Записать(); Пост1.Провести();

    Пост2 = Документы.ПоступлениеТоваров.Создать();
    Пост2.Номер = "ПТ-00002";
    Пост2.Дата = ДатаМес4; Пост2.Организация = НашаОрг; Пост2.Поставщик = ПоставщикГвоздь;
    Пост2.Склад = СкладГлавный;
    Стр = Пост2.Товары.Добавить(); Стр.Номенклатура = НомГвоздь;  Стр.Количество = 300; Стр.Цена = 85; Стр.МестоХранения = МестоСтеллаж1;
    Стр = Пост2.Товары.Добавить(); Стр.Номенклатура = НомСаморез; Стр.Количество = 500; Стр.Цена = 3;  Стр.МестоХранения = МестоСтеллаж2;
    Пост2.Записать(); Пост2.Провести();

    Пост3 = Документы.ПоступлениеТоваров.Создать();
    Пост3.Номер = "ПТ-00003";
    Пост3.Дата = ДатаМес3; Пост3.Организация = НашаОрг; Пост3.Поставщик = ПоставщикФурнитура;
    Пост3.Склад = СкладГлавный;
    Стр = Пост3.Товары.Добавить(); Стр.Номенклатура = НомПетля; Стр.Количество = 100; Стр.Цена = 180; Стр.МестоХранения = МестоСтеллаж2;
    Стр = Пост3.Товары.Добавить(); Стр.Номенклатура = НомЗамок; Стр.Количество = 50;  Стр.Цена = 450; Стр.МестоХранения = МестоПолка;
    Пост3.Записать(); Пост3.Провести();

    Пост4 = Документы.ПоступлениеТоваров.Создать();
    Пост4.Номер = "ПТ-00004";
    Пост4.Дата = ДатаМес2; Пост4.Организация = НашаОрг; Пост4.Поставщик = ПоставщикСмесь;
    Пост4.Склад = СкладГлавный;
    Стр = Пост4.Товары.Добавить(); Стр.Номенклатура = НомШпаклёвка; Стр.Количество = 60; Стр.Цена = 420; Стр.МестоХранения = МестоСтеллаж1;
    Стр = Пост4.Товары.Добавить(); Стр.Номенклатура = НомКраска;    Стр.Количество = 30; Стр.Цена = 2800; Стр.МестоХранения = МестоПолка;
    Стр = Пост4.Товары.Добавить(); Стр.Номенклатура = НомЦемент;    Стр.Количество = 80; Стр.Цена = 550; Стр.МестоХранения = МестоСтеллаж2;
    Пост4.Записать(); Пост4.Провести();

    Пост5 = Документы.ПоступлениеТоваров.Создать();
    Пост5.Номер = "ПТ-00005";
    Пост5.Дата = ДатаМес1; Пост5.Организация = НашаОрг; Пост5.Поставщик = ПоставщикДоски;
    Пост5.Склад = СкладГлавный;
    Стр = Пост5.Товары.Добавить(); Стр.Номенклатура = НомДоска; Стр.Количество = 150; Стр.Цена = 350; Стр.МестоХранения = МестоСтеллаж1;
    Стр = Пост5.Товары.Добавить(); Стр.Номенклатура = НомБрус;  Стр.Количество = 40;  Стр.Цена = 520; Стр.МестоХранения = МестоСтеллаж2;
    Пост5.Записать(); Пост5.Провести();

    Пост6 = Документы.ПоступлениеТоваров.Создать();
    Пост6.Номер = "ПТ-00006";
    Пост6.Дата = ДатаМес1; Пост6.Организация = НашаОрг; Пост6.Поставщик = ПоставщикГвоздь;
    Пост6.Склад = СкладГлавный;
    Стр = Пост6.Товары.Добавить(); Стр.Номенклатура = НомГвоздь;  Стр.Количество = 200; Стр.Цена = 85; Стр.МестоХранения = МестоСтеллаж1;
    Стр = Пост6.Товары.Добавить(); Стр.Номенклатура = НомСаморез; Стр.Количество = 300; Стр.Цена = 3;  Стр.МестоХранения = МестоСтеллаж2;
    Пост6.Записать(); Пост6.Провести();

    Пост7 = Документы.ПоступлениеТоваров.Создать();
    Пост7.Номер = "ПТ-00007";
    Пост7.Дата = ДеньМ14; Пост7.Организация = НашаОрг; Пост7.Поставщик = ПоставщикФурнитура;
    Пост7.Склад = СкладГлавный;
    Стр = Пост7.Товары.Добавить(); Стр.Номенклатура = НомПетля; Стр.Количество = 50; Стр.Цена = 180; Стр.МестоХранения = МестоСтеллаж2;
    Стр = Пост7.Товары.Добавить(); Стр.Номенклатура = НомЗамок; Стр.Количество = 25; Стр.Цена = 450; Стр.МестоХранения = МестоПолка;
    Пост7.Записать(); Пост7.Провести();

    Пост8 = Документы.ПоступлениеТоваров.Создать();
    Пост8.Номер = "ПТ-00008";
    Пост8.Дата = ДеньМ5; Пост8.Организация = НашаОрг; Пост8.Поставщик = ПоставщикСмесь;
    Пост8.Склад = СкладГлавный;
    Стр = Пост8.Товары.Добавить(); Стр.Номенклатура = НомЦемент;    Стр.Количество = 40; Стр.Цена = 550; Стр.МестоХранения = МестоСтеллаж2;
    Стр = Пост8.Товары.Добавить(); Стр.Номенклатура = НомШпаклёвка; Стр.Количество = 30; Стр.Цена = 420; Стр.МестоХранения = МестоСтеллаж1;
    Пост8.Записать(); Пост8.Провести();

    Сообщить("Поступления товаров (8 шт.) проведены.");

    // ---- ОПРИХОДОВАНИЯ (1 шт., сегодня) ----

    Опр1 = Документы.ОприходованиеТоваров.Создать();
    Опр1.Номер = "ОПР-00001";
    Опр1.Дата = Сегодня; Опр1.Организация = НашаОрг; Опр1.Склад = СкладГлавный;
    Опр1.Причина = "Обнаружены за стеллажом — вероятно, с прошлого века";
    Стр = Опр1.Товары.Добавить(); Стр.Номенклатура = НомМолоток; Стр.Количество = 20; Стр.Цена = 650;
    Стр = Опр1.Товары.Добавить(); Стр.Номенклатура = НомПила;    Стр.Количество = 10; Стр.Цена = 890;
    Опр1.Записать(); Опр1.Провести();

