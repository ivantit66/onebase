// Проведение учёта времени — записывает затраченные часы в регистр.

Процедура ОбработкаПроведения()

  Движения.ЗатраченноеВремя.Очистить();

  Дв = Движения.ЗатраченноеВремя.Добавить();
  Дв.Задача       = this.Задача;
  Дв.Исполнитель  = this.Исполнитель;
  Дв.Проект       = this.Задача.Проект;
  Дв.ТипРаботы    = this.ТипРаботы;
  Дв.Часы         = this.Часы;

КонецПроцедуры
