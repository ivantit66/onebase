// Обработчики событий управляемой формы «Клиент».

// @directive=&НаСервере
Процедура ПриОткрытииФормы()
    Если НЕ ЗначениеЗаполнено(Объект.ДатаРегистрации) Тогда
        Объект.ДатаРегистрации = ТекущаяДата();
    КонецЕсли;
    Если НЕ ЗначениеЗаполнено(Объект.Статус) Тогда
        Объект.Статус = "Потенциальный";
    КонецЕсли;
КонецПроцедуры
