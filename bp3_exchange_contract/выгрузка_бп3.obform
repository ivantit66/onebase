    Функция БлокНастройки(Орг)
      Организации = Новый Массив;
      Если ЗначениеЗаполнено(Орг.Получить("ИНН")) Тогда
        Организации.Добавить(Орг.Получить("ИНН"));
      КонецЕсли;

      Объекты = Новый Массив;
      Объекты.Добавить("РеализацияТоваровУслуг");

      Источник = Новый Соответствие;
      Источник.Вставить("конфигурация", "OneBase-PuT");
      Источник.Вставить("имяБазы", "PUTDemo");

      Экспортёр = Новый Соответствие;
      Экспортёр.Вставить("версия", "0.1.0");
      Экспортёр.Вставить("собран", "2026-06-20");

      Н = Новый Соответствие;
      Н.Вставить("организации", Организации);
      Н.Вставить("объекты", Объекты);
      Н.Вставить("источник", Источник);
      Н.Вставить("экспортёр", Экспортёр);
      Н.Вставить("транспорт", "JSON");
      Возврат Н;
    КонецФункции
